Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Aruco Detection Result1
        - /Aruco 2011
        - /Aruco 2021
        - /Aruco 3011
        - /Aruco 3021
        - /Aruco 3031
        - /Aruco 3041
        - /Aruco 3051
        - /Aruco 4011
        - /Aruco 4021
