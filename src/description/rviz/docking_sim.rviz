        - /Dock Position1
        - /Dock Station1
        - /Dock Station1/Status1
        - /Dock Station1/Topic1
        - /Dock Station1/Namespaces1
      Splitter Ratio: 0.5
    Tree Height: 737
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: LEDs PointCloud2
