@article{app14167162,
  abstract       = {The You Only Look Once (YOLO) series of object detection models is widely recognized for its efficiency and real-time performance, particularly under the challenging conditions of underwater environments, characterized by insufficient lighting and visual disturbances. By modifying the YOLOv9s model, this study aims to improve the accuracy and real-time capabilities of underwater object detection, resulting in the introduction of the YOLOv9s-UI detection model. The proposed model incorporates the Dual Dynamic Token Mixer (D-Mixer) module from TransXNet to improve feature extraction capabilities. Additionally, it integrates a feature fusion network design from the LocalMamba network, employing channel and spatial attention mechanisms. These attention modules effectively guide the feature fusion process, significantly enhancing detection accuracy while maintaining the model’s compact size of only 9.3 M. Experimental evaluation on the UCPR2019 underwater object dataset shows that the YOLOv9s-UI model has higher accuracy and recall than the existing YOLOv9s model, as well as excellent real-time performance. This model significantly improves the ability of underwater target detection by introducing advanced feature extraction and attention mechanisms. The model meets portability requirements and provides a more efficient solution for underwater detection.},
  article-number = {7162},
  author         = {Pan, Wei and Chen, Jiabao and Lv, Bangjun and Peng, Likun},
  doi            = {10.3390/app14167162},
  issn           = {2076-3417},
  journal        = {Applied Sciences},
  number         = {16},
  title          = {Optimization and Application of Improved YOLOv9s-UI for Underwater Object Detection},
  url            = {https://www.mdpi.com/2076-3417/14/16/7162},
  volume         = {14},
  year           = {2024}
}


@article{DAS20253042,
  abstract = {Low light object detection in dark environments is very complicated due to the fact that there is always low visibility, low contrast and a lot of noise, which impact on the conventional object detection systems negatively. This paper proposes a Domain Adaptive framework YOLO-D integrating low-light enhancement techniques with multiscale domain adaption in order to improve object detection in difficult illumination conditions. The proposed framework builds on the YOLOv8 architecture by including a Low Light Enhancement Module(LLEM) that preprocesses images to increase exposure and increase their contrast while reducing any noise within them. In order to ensure robustness against domain shifts due to different illumination levels along with a Multiscale Domain Adaptive Network(MS-DAN) is utilized to perform domain adaption at various levels of feature extraction. A strategy for adversarial learning combined with unsupervised learning is used to train the YOLO-D framework so that detection accuracy and domain adaptation are optimized. From experiments done on benchmark dataset ExDark, YOLO-D outperforms other SOTA models, especially under very low light conditions with 97.6% of Mean Average Precision.},
  author   = {Partha Pratim Das and Tanudeep Ganguly and Rapti Chaudhuri and Suman Deb},
  doi      = {https://doi.org/10.1016/j.procs.2025.04.562},
  issn     = {1877-0509},
  journal  = {Procedia Computer Science},
  keywords = {Low-light object detection, LLEM, MS-DAN, Domain Adaptive Framework, YOLO-D},
  note     = {International Conference on Machine Learning and Data Engineering},
  pages    = {3042-3051},
  title    = {YOLO-D: A Domain Adaptive approach towards low light object detection},
  url      = {https://www.sciencedirect.com/science/article/pii/S1877050925016667},
  volume   = {258},
  year     = {2025}
}


