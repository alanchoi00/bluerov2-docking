graph TD
    %% Sensor layer
    subgraph S["Sensor Layer"]
        cam["Camera"]
        imu["IMU"]
        depth["Depth / Range Sensor"]
    end

    %% Perception pipeline
    cam --> pre["Pre-processing<br/>(colour correction,<br/> denoising, enhancement)"]

    %% Two-level detection
    pre --> detL["Light-Cue Detection<br/>(LED array / beacons)"]
    pre --> detM["Marker Detection<br/>(AprilTag / ArUco / CNN ROI)"]

    %% Pose estimation per level
    detL --> poseL["Light-Based Pose Estimation<br/>(Level I, coarse P_L)"]
    detM --> poseM["Marker-Based Pose Estimation<br/>(Level II, precise P_A)"]

    %% Fusion and state estimation
    poseL --> fuse["Fusion + State Estimation<br/>(weighted P_L / P_A,<br/> temporal filtering)"]
    poseM --> fuse
    imu --> fuse
    depth --> fuse

    %% Control and actuators
    fuse --> ctrl["Controller<br/>(approach, alignment,<br/> final docking)"]
    ctrl --> thr["Thrusters /<br/>ROV Actuators"]

    %% Supervisory logic
    fuse --> sup["Supervisory Logic<br/>(mode switching,<br/> abort, fallback)"]
    sup --> ctrl
    sup --> op["Manual Operator /<br/>Fallback Mode"]

    %% Environment / dock
    env["Free-floating Dock<br/>+ Underwater Environment"] --> cam